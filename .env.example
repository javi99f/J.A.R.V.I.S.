GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# Audio and privacy. "wakeword" keeps room audio local until "Hey Jarvis".
# Use "continuous" only for troubleshooting, or "manual" for text/touch only.
WAKE_MODE=wakeword
WAKE_THRESHOLD=0.40
WAKE_CONFIRM_FRAMES=2
# Leave VAD at zero for quiet USB microphones. The wake model remains local.
WAKE_VAD_THRESHOLD=0
WAKE_AUTO_GAIN=1
CONVERSATION_TIMEOUT_SECONDS=12
VOICE_RMS_THRESHOLD=300
INPUT_DEVICE=
OUTPUT_DEVICE=
# Same local developer password hash used by the Raspberry edition. Replace it
# with SHA-256(your private password) before sharing this installation.
DEVELOPER_PASSWORD_SHA256=0294388c97bf9af0ffd74b35daf403e0c1d149b08f3f6f52c6bd43800b8de1c6
JARVIS_VOICE=Charon
APP_MODE=raspberry_pi
DISPLAY_ROTATION=left
DISPLAY_RESOLUTION=1024x600
LIVE_OPEN_TIMEOUT_SECONDS=45
# The Pi tries IPv4 first, then keeps the normal resolver as a fallback.
LIVE_IP_MODE=ipv4-first
LIVE_USE_SYSTEM_PROXY=0

# Public GitHub repository used by the built-in updater. Configure this once
# with the repository that will publish Jarvis Releases.
UPDATE_REPOSITORY=javi99f/J.A.R.V.I.S.
UPDATE_ALLOW_PRERELEASE=0

# Optional Bluetooth speaker. Leave empty to use the system default output.
BLUETOOTH_SPEAKER_MAC=

# Optional: enables Instagram/TikTok analytics through Zernio.
ZERNIO_API_KEY=your-zernio-api-key

# Optional: enables Home Assistant smart-home controls.
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=your-home-assistant-long-lived-access-token
